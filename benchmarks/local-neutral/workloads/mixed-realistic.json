      "weight": 10
    },
    {
      "method": "GET",
      "path": "/private",
      "headers": { "x-api-key": "benchmark-secret" },
      "weight": 5
    },
    { "method": "GET", "path": "/public/hello.txt", "weight": 5 }
  ]
}
