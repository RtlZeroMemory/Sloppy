{
  "schemaVersion": 1,
  "name": "sloppy-runtime-dependencies",
  "statusVocabulary": [
    "found",
    "missing",
    "wrong version",
    "unsupported platform",
    "optional unavailable",
    "corrupt dependency"
  ],
  "platformStatusVocabulary": [
    "supported",
    "experimental",
    "source-build only",
    "planned",
    "unavailable",
    "untested"
  ],
  "toolchainPolicy": {
    "cmake": {
      "required": true,
      "minimumVersion": "3.25.0",
      "command": "cmake",
      "versionArguments": ["--version"],
      "versionPattern": "cmake version ([0-9]+\\.[0-9]+\\.[0-9]+)"
    },
    "ninja": {
      "required": true,
      "minimumVersion": "1.10.0",
      "command": "ninja",
      "versionPattern": "^([0-9]+\\.[0-9]+\\.[0-9]+)"
    },
    "git": {
      "required": true,
      "minimumVersion": "2.40.0",
      "command": "git",
      "versionArguments": ["--version"],
      "versionPattern": "git version ([0-9]+\\.[0-9]+\\.[0-9]+)"
    },
    "vcpkg": {
      "required": true,
      "minimumVersion": null,
      "command": "vcpkg",
      "resolution": ".sdeps/vcpkg, VCPKG_ROOT, PATH, or Visual Studio bundled vcpkg with scripts/buildsystems/vcpkg.cmake",
      "reason": "Required C dependency manager and CMake toolchain for configure/build."
    },
    "rust": {
      "required": true,
      "minimumVersion": "1.93.0",
      "command": "cargo",
      "versionArguments": ["--version"],
      "versionPattern": "cargo ([0-9]+\\.[0-9]+\\.[0-9]+)"
    },
    "node": {
      "required": false,
      "minimumVersion": "20.0.0",
      "command": "node",
      "versionArguments": ["--version"],
      "versionPattern": "v([0-9]+\\.[0-9]+\\.[0-9]+)",
      "reason": "Optional bootstrap stdlib fixture execution; Sloppy app code still uses Sloppy-managed artifacts."
    },
    "python": {
      "required": false,
      "minimumVersion": "3.11.0",
      "command": "python",
      "versionArguments": ["--version"],
      "versionPattern": "Python ([0-9]+\\.[0-9]+\\.[0-9]+)",
      "reason": "Optional local helper scripts only."
    },
    "docker": {
      "required": false,
      "minimumVersion": "24.0.0",
      "command": "docker",
      "versionArguments": ["--version"],
      "versionPattern": "Docker version ([0-9]+\\.[0-9]+\\.[0-9]+)",
      "reason": "Optional live-provider and future release dry-run lanes."
    }
  },
  "platforms": {
    "windows-x64": {
      "status": "supported",
      "runner": "windows-latest",
      "defaultPreset": "windows-dev",
      "compiler": "clang-cl",
      "linker": "lld-link",
      "v8SdkPlatform": "windows-x64",
      "notes": "Current most complete local development and CI lane."
    },
    "linux-x64": {
      "status": "supported",
      "runner": "ubuntu-latest",
      "defaultPresets": ["linux-clang", "linux-gcc"],
      "compiler": "clang or gcc",
      "v8SdkPlatform": "linux-x64",
      "notes": "Default hosted CI lane remains non-V8. Linux x64 V8 uses the Sloppy-owned SDK built by tools/unix/build-v8.sh until a hosted SDK artifact is attached."
    },
    "macos-arm64": {
      "status": "experimental",
      "runner": "macos-latest",
      "defaultPreset": "macos-clang",
      "compiler": "clang",
      "v8SdkPlatform": null,
      "notes": "Hosted non-V8 CI path is represented by the macOS preset; local architecture depends on runner image."
    },
    "macos-x64": {
      "status": "source-build only",
      "runner": "macos-latest",
      "defaultPreset": "macos-clang",
      "compiler": "clang",
      "v8SdkPlatform": null,
      "notes": "No separate x64 package or V8 SDK artifact is published in this package lane."
    },
    "windows-arm64": {
      "status": "planned",
      "runner": null,
      "defaultPreset": null,
      "compiler": "clang-cl",
      "v8SdkPlatform": null,
      "notes": "Planned platform; build, package, and V8 SDK lanes are not available yet."
    }
  },
  "features": {
    "v8": {
      "status": "experimental",
      "defaultMode": "AUTO",
      "supportedModes": ["OFF", "AUTO", "REQUIRED"],
      "evidence": "V8-gated Windows and Linux lanes only when a compatible Sloppy-owned SDK resolves."
    },
    "http": {
      "status": "experimental",
      "evidence": "Bounded HTTP/1.1 local development lane."
    },
    "httpsTls": {
      "status": "planned",
      "evidence": "TLS listener behavior is out of scope for the current dogfood/runtime evidence catalog."
    },
    "sqlite": {
      "status": "experimental",
      "evidence": "Scoped native/runtime SQLite lanes only."
    },
    "postgresql": {
      "status": "experimental",
      "evidence": "Native/libpq and metadata lanes exist; live-provider evidence is separate."
    },
    "sqlServer": {
      "status": "experimental",
      "evidence": "Windows ODBC-backed lane only where driver/runtime dependencies exist."
    },
    "dockerLiveProviders": {
      "status": "optional unavailable",
      "evidence": "Docker is optional; absent Docker is reported as unavailable for live-provider lanes."
    },
    "simd": {
      "status": "supported",
      "evidence": "Scalar canonical path with explicit SIMD presets and separate evidence lanes."
    }
  },
  "v8Sdk": {
    "name": "sloppy-v8-sdk",
    "versionLabel": "v8-7221f49fdb6c89cce6be08005732ebcab3c45b38",
    "v8Revision": "7221f49fdb6c89cce6be08005732ebcab3c45b38",
    "crLibcxxRevision": "af4386908c3762433d412689038de6e6333f5921",
    "buildType": "release",
    "crtCompatibility": "Release or RelWithDebInfo",
    "cacheLayout": ".sdeps/v8/<platform-arch>",
    "advancedOverrideEnv": "SLOPPY_V8_ROOT",
    "hintsEnv": "SLOPPY_V8_SDK_HINTS",
    "artifactSource": {
      "status": "active",
      "downloadImplemented": true,
      "transport": "github-release-asset",
      "cacheLayout": ".sdeps/v8/_downloads",
      "reason": "Windows x64 has a pinned, checksum-validated GitHub release asset. Linux x64 has a source SDK builder and local package lane until the validated SDK archive is attached as a hosted release asset. Other platform SDK artifacts remain planned.",
      "platforms": {
        "windows-x64": {
          "status": "available",
          "archive": "sloppy-v8-sdk-windows-x64-v8-7221f49fdb6c89cce6be08005732ebcab3c45b38.zip",
          "url": "https://github.com/RtlZeroMemory/Slop/releases/download/v8-sdk-windows-x64-v8-7221f49fdb6c89cce6be08005732ebcab3c45b38/sloppy-v8-sdk-windows-x64-v8-7221f49fdb6c89cce6be08005732ebcab3c45b38.zip",
          "sha256": "cce266afcc89948407dd300c857a454d0ce1fe10849004589973879a3b03e27e",
          "sizeBytes": 227614365,
          "release": "https://github.com/RtlZeroMemory/Slop/releases/tag/v8-sdk-windows-x64-v8-7221f49fdb6c89cce6be08005732ebcab3c45b38"
        },
        "linux-x64": {
          "status": "source-build only",
          "archive": "sloppy-v8-sdk-linux-x64-v8-7221f49fdb6c89cce6be08005732ebcab3c45b38.tar.gz",
          "reason": "tools/unix/build-v8.sh builds and packages the pinned Linux x64 SDK locally; hosted artifact URL, checksum, and size must be filled only after upload."
        },
        "macos-arm64": {
          "status": "planned",
          "reason": "No macOS arm64 V8 SDK artifact has been built and validated yet."
        },
        "macos-x64": {
          "status": "planned",
          "reason": "No macOS x64 V8 SDK artifact has been built and validated yet."
        }
      }
    },
    "platforms": {
      "windows-x64": {
        "status": "supported",
        "abi": {
          "v8TargetArch": "x64",
          "v8CompressPointers": true,
          "v8CompressPointersInSharedCage": true,
          "v8_31BitSmisOn64BitArch": false,
          "v8EnableSandbox": true
        },
        "requiredFiles": [
          "include/v8.h",
          "include/libplatform/libplatform.h",
          "lib/v8_monolith*.lib or lib/v8.lib",
          "lib/v8_libplatform*.lib",
          "lib/v8_libbase*.lib",
          "share/sloppy-v8-sdk.json"
        ],
        "optionalRuntimeFiles": ["bin/*.dll"]
      },
      "linux-x64": {
        "status": "source-build only",
        "abi": {
          "v8TargetArch": "x64",
          "v8CompressPointers": true,
          "v8CompressPointersInSharedCage": true,
          "v8_31BitSmisOn64BitArch": false,
          "v8EnableSandbox": true,
          "v8EnableWebAssembly": false
        },
        "requiredFiles": [
          "include/v8.h",
          "include/libplatform/libplatform.h",
          "lib/libv8_monolith.a or lib/libv8_monolith.so",
          "lib/libv8_libplatform.a or lib/libv8_libplatform.so",
          "lib/libv8_libbase.a or lib/libv8_libbase.so",
          "lib/libc++.a or lib/libc++.so",
          "lib/libc++abi.a",
          "support/libcxx/include/",
          "support/libcxx/buildtools/__config_site",
          "share/sloppy-v8-sdk.json"
        ],
        "optionalRuntimeFiles": ["bin/*.so", "lib/*.so"]
      },
      "macos-arm64": {
        "status": "planned",
        "requiredFiles": [],
        "optionalRuntimeFiles": ["bin/*.dylib"]
      },
      "macos-x64": {
        "status": "planned",
        "requiredFiles": [],
        "optionalRuntimeFiles": ["bin/*.dylib"]
      }
    }
  }
}
