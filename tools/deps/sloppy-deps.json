{
  "schemaVersion": 1,
  "name": "sloppy-alpha-infra-dependencies",
  "statusVocabulary": [
    "found",
    "missing",
    "wrong version",
    "unsupported platform",
    "optional unavailable",
    "corrupt dependency"
  ],
  "platformStatusVocabulary": [
    "supported",
    "experimental",
    "source-build only",
    "planned",
    "unavailable",
    "untested"
  ],
  "toolchainPolicy": {
    "cmake": {
      "required": true,
      "minimumVersion": "3.25.0",
      "command": "cmake",
      "versionPattern": "cmake version ([0-9]+\\.[0-9]+\\.[0-9]+)"
    },
    "ninja": {
      "required": true,
      "minimumVersion": "1.10.0",
      "command": "ninja",
      "versionPattern": "^([0-9]+\\.[0-9]+\\.[0-9]+)"
    },
    "git": {
      "required": true,
      "minimumVersion": "2.40.0",
      "command": "git",
      "versionArguments": ["--version"],
      "versionPattern": "git version ([0-9]+\\.[0-9]+\\.[0-9]+)"
    },
    "rust": {
      "required": true,
      "minimumVersion": "1.76.0",
      "command": "cargo",
      "versionArguments": ["--version"],
      "versionPattern": "cargo ([0-9]+\\.[0-9]+\\.[0-9]+)"
    },
    "node": {
      "required": false,
      "minimumVersion": "20.0.0",
      "command": "node",
      "versionArguments": ["--version"],
      "versionPattern": "v([0-9]+\\.[0-9]+\\.[0-9]+)",
      "reason": "Optional bootstrap stdlib fixture execution; Sloppy app code does not claim Node compatibility."
    },
    "python": {
      "required": false,
      "minimumVersion": "3.11.0",
      "command": "python",
      "versionArguments": ["--version"],
      "versionPattern": "Python ([0-9]+\\.[0-9]+\\.[0-9]+)",
      "reason": "Optional local helper scripts only."
    },
    "docker": {
      "required": false,
      "minimumVersion": "24.0.0",
      "command": "docker",
      "versionArguments": ["--version"],
      "versionPattern": "Docker version ([0-9]+\\.[0-9]+\\.[0-9]+)",
      "reason": "Optional live-provider and future release dry-run lanes."
    }
  },
  "platforms": {
    "windows-x64": {
      "status": "supported",
      "runner": "windows-latest",
      "defaultPreset": "windows-dev",
      "compiler": "clang-cl",
      "linker": "lld-link",
      "v8SdkPlatform": "windows-x64",
      "notes": "Current most complete local development and CI lane."
    },
    "linux-x64": {
      "status": "supported",
      "runner": "ubuntu-latest",
      "defaultPresets": ["linux-clang", "linux-gcc"],
      "compiler": "clang or gcc",
      "v8SdkPlatform": null,
      "notes": "Default non-V8 hosted CI lane. V8 SDK artifact lane is not implemented yet."
    },
    "macos-arm64": {
      "status": "experimental",
      "runner": "macos-latest",
      "defaultPreset": "macos-clang",
      "compiler": "clang",
      "v8SdkPlatform": null,
      "notes": "Hosted non-V8 CI path is represented by the macOS preset; local architecture depends on runner image."
    },
    "macos-x64": {
      "status": "source-build only",
      "runner": "macos-latest",
      "defaultPreset": "macos-clang",
      "compiler": "clang",
      "v8SdkPlatform": null,
      "notes": "No separate x64 package or V8 SDK artifact is published in this wave."
    },
    "windows-arm64": {
      "status": "planned",
      "runner": null,
      "defaultPreset": null,
      "compiler": "clang-cl",
      "v8SdkPlatform": null,
      "notes": "Planned platform; no build, package, or V8 SDK lane is claimed."
    }
  },
  "features": {
    "v8": {
      "status": "experimental",
      "defaultMode": "AUTO",
      "supportedModes": ["OFF", "AUTO", "REQUIRED"],
      "evidence": "V8-gated Windows lane only when a compatible SDK resolves."
    },
    "http": {
      "status": "experimental",
      "evidence": "Bounded HTTP/1.1 internal alpha lane; no production edge claim."
    },
    "httpsTls": {
      "status": "planned",
      "evidence": "TLS listener behavior is out of ALPHA-INFRA Wave 1 scope."
    },
    "sqlite": {
      "status": "experimental",
      "evidence": "Scoped native/runtime SQLite lanes only."
    },
    "postgresql": {
      "status": "experimental",
      "evidence": "Native/libpq and metadata lanes exist; live-provider evidence is separate."
    },
    "sqlServer": {
      "status": "experimental",
      "evidence": "Windows ODBC-backed lane only where driver/runtime dependencies exist."
    },
    "dockerLiveProviders": {
      "status": "optional unavailable",
      "evidence": "Docker is optional and never counts as live-provider pass evidence when absent."
    },
    "simd": {
      "status": "supported",
      "evidence": "Scalar canonical path with explicit SIMD presets and separate evidence lanes."
    }
  },
  "v8Sdk": {
    "name": "sloppy-v8-sdk",
    "versionLabel": "v8-7221f49fdb6c89cce6be08005732ebcab3c45b38",
    "v8Revision": "7221f49fdb6c89cce6be08005732ebcab3c45b38",
    "crLibcxxRevision": "af4386908c3762433d412689038de6e6333f5921",
    "buildType": "release",
    "crtCompatibility": "Release or RelWithDebInfo",
    "cacheLayout": ".sdeps/v8/<platform-arch>",
    "advancedOverrideEnv": "SLOPPY_V8_ROOT",
    "hintsEnv": "SLOPPY_V8_SDK_HINTS",
    "artifactSource": {
      "status": "planned",
      "downloadImplemented": false,
      "reason": "No public pinned SDK artifact source is selected in Wave 1; resolver validates local cache or explicit override only."
    },
    "platforms": {
      "windows-x64": {
        "status": "supported",
        "abi": {
          "v8TargetArch": "x64",
          "v8CompressPointers": true,
          "v8CompressPointersInSharedCage": true,
          "v8_31BitSmisOn64BitArch": true,
          "v8EnableSandbox": true
        },
        "requiredFiles": [
          "include/v8.h",
          "include/libplatform/libplatform.h",
          "lib/v8_monolith*.lib or lib/v8.lib",
          "lib/v8_libplatform*.lib",
          "lib/v8_libbase*.lib",
          "share/sloppy-v8-sdk.json"
        ],
        "optionalRuntimeFiles": ["bin/*.dll"]
      },
      "linux-x64": {
        "status": "planned",
        "requiredFiles": [],
        "optionalRuntimeFiles": ["bin/*.so"]
      },
      "macos-arm64": {
        "status": "planned",
        "requiredFiles": [],
        "optionalRuntimeFiles": ["bin/*.dylib"]
      },
      "macos-x64": {
        "status": "planned",
        "requiredFiles": [],
        "optionalRuntimeFiles": ["bin/*.dylib"]
      }
    }
  }
}
