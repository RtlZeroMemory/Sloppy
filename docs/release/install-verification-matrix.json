{
  "schemaVersion": 1,
  "matrix": "sloppy.release-install-verification",
  "statusVocabulary": ["PASS", "FAIL", "SKIPPED", "UNAVAILABLE", "NOT RUN"],
  "lanes": [
    {
      "id": "windows-archive",
      "status": "NOT RUN",
      "requiredEvidence": ["package", "test-package", "sloppy --version", "sloppy doctor", "sloppyc --version", "prebuilt artifact smoke"],
      "notes": "Filled by local/CI evidence in the release-dist PR body."
    },
    {
      "id": "linux-archive",
      "status": "UNAVAILABLE",
      "requiredEvidence": ["Linux source build", "Linux package", "outside-checkout smoke", "external app build", "runtime execution or explicit V8 blocker"],
      "notes": "Linux x64 is required. Full runtime-user support remains blocked until Linux package/runtime evidence passes."
    },
    {
      "id": "macos-arm64-archive",
      "status": "NOT RUN",
      "requiredEvidence": ["hosted package dry-run", "outside-checkout smoke"],
      "notes": "Hosted evidence belongs to the manual release-artifacts workflow."
    },
    {
      "id": "macos-x64-archive",
      "status": "SKIPPED",
      "requiredEvidence": ["optional hosted x64 package dry-run"],
      "notes": "Optional/source-build-only unless requested."
    },
    {
      "id": "npm-root-launcher",
      "status": "NOT RUN",
      "requiredEvidence": ["npm pack dry-run", "local tarball install", "sloppy --version", "sloppy doctor", "missing platform diagnostic", "unsupported platform diagnostic"],
      "notes": "npm is a runtime installer only."
    },
    {
      "id": "npm-platform-packages",
      "status": "NOT RUN",
      "requiredEvidence": ["platform package generated from archive contents", "npm pack dry-run", "no native install scripts", "alpha dist-tag policy"],
      "notes": "Platform packages must not independently build Sloppy."
    },
    {
      "id": "v8-package-lane",
      "status": "NOT RUN",
      "requiredEvidence": ["V8-enabled build", "V8 runtime files bundled", "V8-backed hello execution"],
      "notes": "Non-V8 package smoke is not V8 runtime evidence."
    },
    {
      "id": "live-providers",
      "status": "SKIPPED",
      "requiredEvidence": ["PostgreSQL live lane", "SQL Server live lane"],
      "notes": "Live providers are opt-in and not default package evidence."
    }
  ]
}
