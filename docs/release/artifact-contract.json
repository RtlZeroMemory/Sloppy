{
  "schemaVersion": 1,
  "contract": "sloppy.release-artifact",
  "contractVersion": "1.0.0",
  "releaseVersionPolicy": "0.1.0-alpha.N until the release gate chooses a concrete N",
  "dryRunDefault": true,
  "canonicalDistribution": "github-release-archives",
  "npmDistributionRole": "convenience launcher for installing Sloppy itself only",
  "statusVocabulary": [
    "supported",
    "experimental",
    "source-build only",
    "planned",
    "blocked",
    "unavailable",
    "untested"
  ],
  "evidenceStatusVocabulary": [
    "PASS",
    "FAIL",
    "SKIPPED",
    "UNAVAILABLE",
    "DEFERRED",
    "NOT RUN"
  ],
  "archiveMatrix": [
    {
      "id": "windows-x64",
      "archiveName": "sloppy-windows-x64.zip",
      "packageRoot": "sloppy-windows-x64",
      "packageFormat": "zip",
      "platformStatus": "experimental",
      "runtimeUserStatus": "experimental pending release dry-run evidence",
      "v8RuntimeStatus": "windows V8 SDK source available; end-user V8 runtime package smoke remains a separate lane"
    },
    {
      "id": "linux-x64",
      "archiveName": "sloppy-linux-x64.tar.gz",
      "packageRoot": "sloppy-linux-x64",
      "packageFormat": "tar.gz",
      "platformStatus": "experimental",
      "runtimeUserStatus": "experimental package smoke when Linux source build and package smoke pass; V8 runtime-user evidence requires the Sloppy-owned Linux x64 SDK and require-v8 package smoke",
      "v8RuntimeStatus": "Linux x64 V8 SDK can be built locally with tools/unix/build-v8.sh; hosted artifact URL and checksum remain pending until upload"
    },
    {
      "id": "macos-arm64",
      "archiveName": "sloppy-macos-arm64.tar.gz",
      "packageRoot": "sloppy-macos-arm64",
      "packageFormat": "tar.gz",
      "platformStatus": "experimental",
      "runtimeUserStatus": "experimental pending hosted package smoke",
      "v8RuntimeStatus": "macOS arm64 V8 SDK/runtime artifact lane is not available yet"
    },
    {
      "id": "macos-x64",
      "archiveName": "sloppy-macos-x64.tar.gz",
      "packageRoot": "sloppy-macos-x64",
      "packageFormat": "tar.gz",
      "platformStatus": "source-build only",
      "runtimeUserStatus": "source-build only unless the optional hosted x64 lane is requested and smoked",
      "v8RuntimeStatus": "macOS x64 V8 SDK/runtime artifact lane is not available yet"
    }
  ],
  "requiredPackageLayout": [
    "bin/sloppy",
    "bin/sloppyc",
    "stdlib/sloppy",
    "templates",
    "examples",
    "docs/KNOWN_LIMITATIONS.md",
    "docs/LICENSES.md",
    "docs/NOTICE.md",
    "manifest.json"
  ],
  "forbiddenPackagePaths": [
    ".git",
    ".sdeps",
    "build",
    "compiler/target",
    "target",
    "vcpkg_installed",
    "engines/v8/include",
    "engines/v8/lib"
  ],
  "requiredManifestFields": [
    "manifestSchema",
    "manifestVersion",
    "name",
    "version",
    "archiveName",
    "packageRoot",
    "platform",
    "arch",
    "platformTriplet",
    "configuration",
    "commit",
    "releaseKind",
    "publicReleaseCreated",
    "canonicalDistribution",
    "npmPackageSource",
    "platformStatus",
    "runtimeUserStatus",
    "v8",
    "dependencyStatuses",
    "knownLimitations",
    "checksums"
  ],
  "checksumFile": "SHA256SUMS.txt",
  "npmPackages": {
    "root": "@rtlzeromemory/sloppy",
    "platformPackages": [
      "@rtlzeromemory/sloppy-win32-x64",
      "@rtlzeromemory/sloppy-linux-x64",
      "@rtlzeromemory/sloppy-darwin-arm64",
      "@rtlzeromemory/sloppy-darwin-x64"
    ],
    "publishTag": "alpha",
    "publishWorkflow": ".github/workflows/npm-publish.yml",
    "publishTrigger": "manual workflow_dispatch",
    "publishAuth": "npm Trusted Publishing/OIDC preferred; granular NPM_TOKEN secret is fallback only",
    "publishOrder": [
      "platform packages",
      "root launcher package"
    ],
    "nodeMinimum": "22.14.0",
    "npmMinimum": "11.5.1",
    "nativeInstallScriptsAllowed": false,
    "nodeGypAllowed": false,
    "postinstallDownloadAllowed": false,
    "platformContentSource": "generated from already built and tested release archive contents"
  },
  "nonGoals": [
    "dry-run only",
    "no automatic npm publish",
    "no latest dist-tag",
    "no installer",
    "no signing",
    "no notarization",
    "Sloppy-managed app artifacts only",
    "no npm app dependency support",
    "no node_modules resolution for Sloppy apps",
    "production readiness tracked separately",
    "performance comparisons require benchmark reports"
  ]
}
