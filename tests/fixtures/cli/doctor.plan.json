{
  "schemaVersion": 1,
  "compilerVersion": "sloppyc-placeholder",
  "runtimeMinimumVersion": "0.1.0",
  "stdlibVersion": "0.1.0",
  "target": {
    "platform": "windows-x64",
    "engine": "v8"
  },
  "bundle": {
    "path": ".sloppy/app.js",
    "id": "cli-doctor-test",
    "hash": "test-only"
  },
  "sourceMap": {
    "path": ".sloppy/app.js.map",
    "id": "cli-doctor-test-map",
    "hash": "test-only"
  },
  "handlers": [
    {
      "id": 1,
      "exportName": "__sloppy_handler_1",
      "displayName": "Doctor.Index"
    }
  ],
  "doctorChecks": [
    {
      "id": "sqlite.provider",
      "status": "ok",
      "message": "sqlite provider metadata available"
    },
    {
      "id": "postgres.live",
      "status": "warn",
      "message": "live PostgreSQL check skipped because SLOPPY_POSTGRES_TEST_URL is not set"
    },
    {
      "id": "sqlserver.driver",
      "status": "error",
      "message": "connectionString=Driver={ODBC Driver 18 for SQL Server};Server=localhost;UID=sa;PWD=<PASSWORD>; Microsoft ODBC Driver 18 for SQL Server not found"
    }
  ]
}
