{
  "schemaVersion": 1,
  "compilerVersion": "sloppyc-placeholder",
  "runtimeMinimumVersion": "0.1.0",
  "stdlibVersion": "0.1.0",
  "target": {
    "platform": "windows-x64",
    "engine": "v8"
  },
  "bundle": {
    "path": ".sloppy/app.js",
    "id": "cli-doctor-test",
    "hash": "test-only"
  },
  "sourceMap": {
    "path": ".sloppy/app.js.map",
    "id": "cli-doctor-test-map",
    "hash": "test-only"
  },
  "handlers": [
    {
      "id": 1,
      "exportName": "__sloppy_handler_1",
      "displayName": "Doctor.Index"
    }
  ],
  "dataProviders": [
    {
      "token": "data.main",
      "provider": "sqlite",
      "providerKind": "sqlite",
      "service": "data.main",
      "database": "app.db"
    },
    {
      "token": "data.analytics",
      "provider": "postgres",
      "providerKind": "postgres",
      "service": "data.analytics",
      "configKey": "Sloppy:Providers:postgres:analytics:connectionString"
    },
    {
      "token": "data.reporting",
      "provider": "sqlserver",
      "providerKind": "sqlserver",
      "service": "data.reporting",
      "configKey": "Sloppy:Providers:sqlserver:reporting:connectionString"
    }
  ]
}
