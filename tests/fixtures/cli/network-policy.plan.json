{
  "schemaVersion": 1,
  "compilerVersion": "sloppyc-placeholder",
  "runtimeMinimumVersion": "0.1.0",
  "stdlibVersion": "0.1.0",
  "target": {
    "platform": "windows-x64",
    "engine": "v8"
  },
  "bundle": {
    "path": ".sloppy/net-policy.js",
    "id": "cli-net-policy-test",
    "hash": "test-only"
  },
  "sourceMap": {
    "path": ".sloppy/net-policy.js.map",
    "id": "cli-net-policy-test-map",
    "hash": "test-only"
  },
  "handlers": [
    {
      "id": 1,
      "exportName": "__sloppy_handler_1",
      "displayName": "Network.Policy"
    }
  ],
  "capabilities": [
    { "token": "net.redis", "kind": "network", "access": "connect" },
    { "token": "net.admin", "kind": "network", "access": "listen" },
    { "token": "net.echo", "kind": "network", "access": "connect-listen" }
  ],
  "doctorChecks": [
    {
      "id": "stdlib.net.policy",
      "status": "ok",
      "message": "network targets are policy-visible; doctor/audit goldens exercise connect/listen metadata without external network access"
    }
  ]
}
