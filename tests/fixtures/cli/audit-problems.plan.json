{
  "schemaVersion": 1,
  "compilerVersion": "sloppyc-placeholder",
  "runtimeMinimumVersion": "0.1.0",
  "stdlibVersion": "0.1.0",
  "target": {
    "platform": "windows-x64",
    "engine": "v8"
  },
  "bundle": {
    "path": ".sloppy/app.js",
    "id": "cli-audit-test",
    "hash": "test-only"
  },
  "sourceMap": {
    "path": ".sloppy/app.js.map",
    "id": "cli-audit-test-map",
    "hash": "test-only"
  },
  "handlers": [
    {
      "id": 1,
      "exportName": "__sloppy_handler_1",
      "displayName": "Users.Get"
    }
  ],
  "routes": [
    {
      "method": "GET",
      "pattern": "/users/{id:int}",
      "handlerId": 1,
      "name": "Users.Get",
      "module": "users",
      "capability": "data.missing"
    },
    {
      "method": "GET",
      "pattern": "/users/{id:int}",
      "handlerId": 99,
      "name": "Users.Get",
      "module": "users"
    }
  ],
  "modules": [
    {
      "name": "users",
      "dependencies": ["data"]
    }
  ],
  "dataProviders": [
    {
      "token": "data.main",
      "provider": "sqlserver",
      "capability": "data.main",
      "requiredAccess": "write"
    }
  ],
  "capabilities": [
    {
      "token": "data.main",
      "kind": "database",
      "access": "read",
      "provider": "data.other"
    },
    {
      "token": "data.main",
      "kind": "database",
      "access": "readwrite",
      "provider": "data.main"
    },
    {
      "token": "files.uploads",
      "kind": "filesystem",
      "access": "read"
    },
    {
      "token": "net.admin",
      "kind": "network",
      "access": "connect"
    }
  ]
}
