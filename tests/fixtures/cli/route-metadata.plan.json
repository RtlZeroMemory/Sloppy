{
  "schemaVersion": 1,
  "compilerVersion": "sloppyc-placeholder",
  "runtimeMinimumVersion": "0.1.0",
  "stdlibVersion": "0.1.0",
  "target": {
    "platform": "windows-x64",
    "engine": "v8"
  },
  "bundle": {
    "path": ".sloppy/app.js",
    "id": "cli-route-test",
    "hash": "test-only"
  },
  "sourceMap": {
    "path": ".sloppy/app.js.map",
    "id": "cli-route-test-map",
    "hash": "test-only"
  },
  "handlers": [
    {
      "id": 1,
      "exportName": "__sloppy_handler_1",
      "displayName": "Hello.Index"
    },
    {
      "id": 2,
      "exportName": "__sloppy_handler_2",
      "displayName": "Users.Get"
    }
  ],
  "routes": [
    {
      "method": "GET",
      "pattern": "/users/{id:int}",
      "handlerId": 2,
      "name": "Users.Get",
      "module": "users"
    },
    {
      "method": "GET",
      "pattern": "/",
      "handlerId": 1,
      "name": "Hello.Index",
      "module": "hello"
    }
  ],
  "modules": [
    {
      "name": "hello",
      "dependencies": []
    },
    {
      "name": "users",
      "dependencies": ["hello"]
    }
  ],
  "dataProviders": [
    {
      "token": "data.main",
      "provider": "sqlite",
      "service": "data.main"
    }
  ]
}
