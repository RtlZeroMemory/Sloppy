{
  "schemaVersion": 1,
  "compilerVersion": "sloppyc-placeholder",
  "runtimeMinimumVersion": "0.1.0",
  "stdlibVersion": "0.1.0",
  "target": {
    "platform": "windows-x64",
    "engine": "v8"
  },
  "bundle": {
    "path": ".sloppy/app.js",
    "id": "cli-audit-escaping",
    "hash": "test-only"
  },
  "sourceMap": {
    "path": ".sloppy/app.js.map",
    "id": "cli-audit-escaping-map",
    "hash": "test-only"
  },
  "configuration": {
    "requirements": [
      {
        "key": "Auth:\u202ESecret\u001B\n\t",
        "type": "string",
        "required": true,
        "status": "missing",
        "source": null,
        "requiredBy": "src/auth.ts:1",
        "redaction": "none",
        "secret": false
      }
    ]
  }
}
