{
  "schemaVersion": 1,
  "compilerVersion": "sloppyc-placeholder",
  "runtimeMinimumVersion": "0.1.0",
  "stdlibVersion": "0.1.0",
  "target": {
    "platform": "windows-x64",
    "engine": "v8"
  },
  "bundle": {
    "path": ".sloppy/app.js",
    "id": "cli-workers-test",
    "hash": "test-only"
  },
  "sourceMap": {
    "path": ".sloppy/app.js.map",
    "id": "cli-workers-test-map",
    "hash": "test-only"
  },
  "handlers": [
    {
      "id": 1,
      "exportName": "__sloppy_handler_1",
      "displayName": "Workers.Policy"
    }
  ],
  "requiredFeatures": ["stdlib.workers"],
  "workers": {
    "static": false,
    "resources": [],
    "policy": {
      "boundedByDefault": true,
      "noRawNativeHandles": true,
      "ownerThreadSettlement": true
    }
  },
  "doctorChecks": [
    {
      "id": "stdlib.workers.contract",
      "status": "ok",
      "message": "Workers are Plan-visible as stdlib.workers; queue, service, pool, and JS worker resources are lifecycle-bound and bounded by default"
    }
  ]
}
