{
  "schemaVersion": 1,
  "archiveKind": "windows-zip",
  "lane": "package outside-checkout",
  "requiresV8Runtime": false,
  "requiredFiles": [
    "README.md",
    "LICENSE",
    "docs/KNOWN_LIMITATIONS.md",
    "docs/LICENSES.md",
    "docs/NOTICE.md",
    "manifest.json"
  ],
  "requiredDirectories": [
    "bin",
    "stdlib",
    "stdlib/sloppy",
    "examples",
    "docs"
  ],
  "requiredStdlibAssets": [
    "index.js",
    "app.js",
    "results.js",
    "schema.js",
    "cache.js",
    "data.js",
    "redis.js",
    "bootstrap.manifest.json",
    "internal/intrinsics.js"
  ],
  "excludedPaths": [
    ".git",
    ".sdeps",
    "build",
    "compiler/target",
    "target",
    "vcpkg_installed"
  ],
  "excludedFiles": [
    "engines/v8/include/v8.h",
    "engines/v8/lib/v8_monolith.lib"
  ],
  "expectedManifest": {
    "name": "sloppy",
    "containsStdlib": true,
    "containsV8Sdk": false
  },
  "outsideCheckoutCompile": false,
  "expectedRun": {
    "artifactMode": true,
    "sourceCompileInRun": false,
    "nonV8Result": "SKIPPED",
    "v8Result": "separate lane"
  },
  "prebuiltArtifactFixture": {
    "path": "compiler/tests/fixtures/hello-mapget/expected",
    "once": {
      "method": "GET",
      "target": "/"
    },
    "stdoutContains": [
      "Hello from Sloppy"
    ]
  },
  "mustNotCompileSource": true
}
