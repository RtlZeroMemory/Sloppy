{
  "openapi": "3.0.3",
  "info": {
    "title": "Sloppy API",
    "version": "0.0.0"
  },
  "x-slop-openapi-policy": {
    "status": "plan-supported-subset",
    "unknownMetadata": "explicit-partial-markers",
    "optimizations": "reported-only"
  },
  "paths": {
    "/me": {
      "get": {
        "operationId": "Users.Me",
        "security": [{ "jwt": [] }],
        "x-slop-auth": {
          "required": true,
          "schemes": ["jwt"],
          "scopes": ["users:read"],
          "roles": ["admin"],
          "policy": "Users.Read"
        },
        "x-slop-completeness": "",
        "x-slop-capabilities": [],
        "x-slop-optimization-candidates": [],
        "parameters": [],
        "responses": {
          "200": { "description": "response metadata unknown", "x-slop-partial": "response metadata unknown" },
          "401": { "description": "authentication failed", "content": { "application/problem+json": { "schema": { "type": "object", "properties": { "status": { "type": "integer" }, "title": { "type": "string" }, "detail": { "type": "string" } } } } } } },
          "403": { "description": "authorization failed", "content": { "application/problem+json": { "schema": { "type": "object", "properties": { "status": { "type": "integer" }, "title": { "type": "string" }, "detail": { "type": "string" } } } } } } }
        }
      }
    },
    "/public": {
      "get": {
        "operationId": "Public.Index",
        "x-slop-auth": {
          "required": false,
          "allowAnonymous": true
        },
        "x-slop-completeness": "",
        "x-slop-capabilities": [],
        "x-slop-optimization-candidates": [],
        "parameters": [],
        "responses": {
          "200": { "description": "response metadata unknown", "x-slop-partial": "response metadata unknown" }
        }
      }
    },
    "/internal/jobs": {
      "post": {
        "operationId": "Internal.Job",
        "security": [{ "apiKey": [] }],
        "x-slop-auth": {
          "required": true,
          "schemes": ["apiKey"],
          "scopes": ["jobs:write"]
        },
        "x-slop-completeness": "",
        "x-slop-capabilities": [],
        "x-slop-optimization-candidates": [],
        "parameters": [],
        "responses": {
          "200": { "description": "response metadata unknown", "x-slop-partial": "response metadata unknown" },
          "401": { "description": "authentication failed", "content": { "application/problem+json": { "schema": { "type": "object", "properties": { "status": { "type": "integer" }, "title": { "type": "string" }, "detail": { "type": "string" } } } } } } },
          "403": { "description": "authorization failed", "content": { "application/problem+json": { "schema": { "type": "object", "properties": { "status": { "type": "integer" }, "title": { "type": "string" }, "detail": { "type": "string" } } } } } } }
        }
      }
    }
  },
  "components": {
    "responses": {
      "SlopValidationProblem": {
        "description": "Slop validation problem response",
        "content": { "application/problem+json": { "schema": { "$ref": "#/components/schemas/SlopValidationProblem" } } }
      }
    },
    "schemas": {
      "SlopValidationProblem": {
        "type": "object",
        "properties": {
          "status": { "type": "integer" },
          "title": { "type": "string" },
          "detail": { "type": "string" }
        }
      }
    },
    "securitySchemes": {
      "jwt": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" },
      "apiKey": { "type": "apiKey", "in": "header", "name": "X-API-Key" },
      "cookieSession": { "type": "apiKey", "in": "cookie", "name": "sloppy.session" }
    }
  }
}
