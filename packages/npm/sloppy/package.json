{
  "name": "@slopware/sloppy",
  "version": "0.1.0-alpha.2",
  "description": "Sloppy runtime launcher. npm installs Sloppy itself; it does not add npm package support to Sloppy apps.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RtlZeroMemory/Sloppy.git"
  },
  "bin": {
    "sloppy": "bin/sloppy.js"
  },
  "files": [
    "bin/",
    "lib/",
    "types/",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "optionalDependencies": {
    "@slopware/sloppy-win32-x64": "0.1.0-alpha.2",
    "@slopware/sloppy-linux-x64": "0.1.0-alpha.2",
    "@slopware/sloppy-darwin-arm64": "0.1.0-alpha.2",
    "@slopware/sloppy-darwin-x64": "0.1.0-alpha.2"
  },
  "publishConfig": {
    "tag": "alpha",
    "access": "public"
  },
  "types": "types/index.d.ts",
  "typesVersions": {
    "*": {
      "os": [
        "types/os.d.ts"
      ],
      "fs": [
        "types/fs.d.ts"
      ],
      "data": [
        "types/data.d.ts"
      ],
      "providers/sqlite": [
        "types/providers/sqlite.d.ts"
      ]
    }
  }
}
